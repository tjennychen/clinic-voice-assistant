# Copy this file to .env and fill in your own values.
# Never commit .env (it's in .gitignore).

# ---------------------------------------------------------------------------
# OpenAI (Realtime API powers the voice agent)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Twilio (inbound calls + SMS)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=        # E.164 format, e.g. +14155551234

# ---------------------------------------------------------------------------
# Google Calendar (availability + booking)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=       # populated by `node get-gcal-token.js`
GOOGLE_CALENDAR_ID=primary  # or a specific calendar ID

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
CLINIC_EMAIL=               # must be verified in Resend

# ---------------------------------------------------------------------------
# Retell (telephony orchestration, optional depending on deployment)
# ---------------------------------------------------------------------------
RETELL_API_KEY=

# ---------------------------------------------------------------------------
# Clinic identity (defaults shown; override per deployment)
# ---------------------------------------------------------------------------
CLINIC_NAME=Acme Acupuncture
CLINIC_PHONE=                       # falls back to TWILIO_PHONE_NUMBER if blank
CLINIC_ADDRESS=
CLINIC_TIMEZONE=America/Los_Angeles
PRACTITIONER_NAME=                  # e.g. "Dr. Smith"; appears in agent script

# ---------------------------------------------------------------------------
# Service pricing (USD, integer dollars)
# ---------------------------------------------------------------------------
NEW_PATIENT_PRICE=255
FOLLOWUP_PRICE=205
HERBAL_PRICE=135

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
GOOGLE_REVIEW_LINK=         # e.g. https://g.page/r/...
PORT=3000
